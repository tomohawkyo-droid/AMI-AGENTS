#!/usr/bin/env bash
set -e

echo "🚀 Installing AMI Agents..."

# 1. Sync venv
echo "📦 Syncing dependencies with uv..."
uv sync

# 1.5 Setup PYTHONPATH via .pth
echo "🔗 Configuring python path..."
VENV_SITE_PACKAGES=$(find .venv -name "site-packages" -type d | head -n 1)
if [[ -n "$VENV_SITE_PACKAGES" ]]; then
    echo "$PWD" > "$VENV_SITE_PACKAGES/ami.pth"
    echo "✅ Linked project root to $VENV_SITE_PACKAGES/ami.pth"
else
    echo "❌ Could not find site-packages in .venv"
    exit 1
fi

# 2. Setup configuration files
# 2a. Automation Config
AUTO_CONFIG="ami/config/automation.yaml"
AUTO_TEMPLATE="ami/config/automation.template.yaml"

if [[ ! -f "$AUTO_CONFIG" ]]; then
    echo "⚙️  Initializing automation configuration..."
    if [[ -f "$AUTO_TEMPLATE" ]]; then
        cp "$AUTO_TEMPLATE" "$AUTO_CONFIG"
        echo "✅ Created $AUTO_CONFIG from template"
    else
        echo "⚠️  Template $AUTO_TEMPLATE not found"
    fi
else
    echo "ℹ️  Automation configuration already exists at $AUTO_CONFIG"
fi

# 2b. Extensions Config
EXT_CONFIG="ami/config/extensions.yaml"
EXT_TEMPLATE="ami/config/extensions.template.yaml"

if [[ ! -f "$EXT_CONFIG" ]]; then
    echo "⚙️  Initializing extensions configuration..."
    if [[ -f "$EXT_TEMPLATE" ]]; then
        cp "$EXT_TEMPLATE" "$EXT_CONFIG"
        echo "✅ Created $EXT_CONFIG from template"
    else
        echo "⚠️  Template $EXT_TEMPLATE not found, creating empty config"
        echo "extensions: []" > "$EXT_CONFIG"
    fi
else
    echo "ℹ️  Extensions configuration already exists at $EXT_CONFIG"
fi

# 3. Register extensions in .bashrc
echo "🔌 Registering extensions in ~/.bashrc..."
BASHRC="$HOME/.bashrc"
MARKER_START="# --- AMI AGENT EXTENSIONS START ---"
MARKER_END="# --- AMI AGENT EXTENSIONS END ---"

# Extract extensions list using python (safer than grep/sed for yaml)
EXTENSIONS=$(python3 -c "
import yaml
try:
    with open('$EXT_CONFIG') as f:
        data = yaml.safe_load(f)
        for ext in data.get('extensions', []):
            print(ext)
except Exception:
    pass
")

if [[ -n "$EXTENSIONS" ]]; then
    # Generate the block of aliases/exports
    NEW_BLOCK=""
    while IFS= read -r cmd; do
        if [[ -n "$cmd" ]]; then
            # Execute the extension command to get the shell setup string (e.g. "alias foo='bar'")
            # We run it from the project root
            SETUP_CMD=$(eval "$cmd")
            if [[ -n "$SETUP_CMD" ]]; then
                NEW_BLOCK+="$SETUP_CMD"$'\n'
            fi
        fi
    done <<< "$EXTENSIONS"

    if [[ -n "$NEW_BLOCK" ]]; then
        # Remove old block if exists
        if grep -q "$MARKER_START" "$BASHRC"; then
            sed -i "/$MARKER_START/,/$MARKER_END/d" "$BASHRC"
        fi
        
        # Append new block
        echo "$MARKER_START" >> "$BASHRC"
        echo "$NEW_BLOCK" >> "$BASHRC"
        echo "$MARKER_END" >> "$BASHRC"
        
        echo "✅ Added/Updated extensions in $BASHRC"
        echo "🔄 Source ~/.bashrc or restart your shell to apply changes."
    fi
else
    echo "ℹ️  No extensions found to register."
fi

echo "✨ Installation complete. Run './ami-agent' to start."
