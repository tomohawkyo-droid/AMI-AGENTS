#!/usr/bin/env bash
# ami-extra: list hidden, degraded, and unavailable extensions
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
AMI_ROOT="$("$SCRIPT_DIR/ami-pwd")"

exec "/home/ami/AMI-AGENTS/.venv/bin/python" "$AMI_ROOT/ami/scripts/shell/banner_helper.py" --mode extra
