#!/usr/bin/env bash
# Podman Guard - Blocks destructive commands
# Installed to ${VENV_DIR}/bin/podman, calls real-podman
#
# This wrapper prevents accidental data loss from dangerous podman commands.
# It cannot be bypassed because it IS the podman binary in PATH.

set -euo pipefail

PODMAN_REAL="$(dirname "$0")/real-podman"

# Ensure real podman exists
if [[ ! -x "$PODMAN_REAL" ]]; then
    echo "ERROR: real-podman not found at $PODMAN_REAL"
    echo "Run bootstrap_podman.sh to fix installation"
    exit 1
fi

block() {
    echo "❌ BLOCKED: $1"
    echo "This command is forbidden to prevent data loss."
    exit 1
}

# Handle empty args
if [[ $# -eq 0 ]]; then
    exec "$PODMAN_REAL"
fi

# Check for destructive commands
case "$1" in
    rm)
        for arg in "$@"; do
            [[ "$arg" == "-a" || "$arg" == "--all" ]] && block "Bulk container removal (rm -a/--all)"
        done
        ;;
    rmi)
        for arg in "$@"; do
            [[ "$arg" == "-a" || "$arg" == "--all" ]] && block "Bulk image removal (rmi -a/--all)"
        done
        ;;
    system)
        case "${2:-}" in
            prune)   block "system prune" ;;
            migrate) block "system migrate (causes state corruption)" ;;
            reset)   block "system reset (destroys all data)" ;;
        esac
        ;;
    volume)
        [[ "${2:-}" == "prune" ]] && block "volume prune"
        if [[ "${2:-}" == "rm" ]]; then
            for arg in "$@"; do
                [[ "$arg" == "-a" || "$arg" == "--all" ]] && block "Bulk volume removal"
            done
        fi
        ;;
    image)
        if [[ "${2:-}" == "prune" ]]; then
            for arg in "$@"; do
                [[ "$arg" == "-a" || "$arg" == "--all" ]] && block "image prune -a"
            done
        fi
        ;;
    container)
        [[ "${2:-}" == "prune" ]] && block "container prune"
        ;;
    network)
        [[ "${2:-}" == "prune" ]] && block "network prune"
        ;;
esac

# Safe - pass through to real podman
exec "$PODMAN_REAL" "$@"
